# Copy to router-config-secret.yaml in this directory and fill locally. Do not commit real Tailnet endpoints.
apiVersion: v1
kind: Secret
metadata:
  name: ollama-router-config
  namespace: ollama-router
type: Opaque
stringData:
  config.yaml: |
    healthcheck_interval_seconds: 30
    healthcheck_timeout_seconds: 5
    request_timeout_seconds: 120

    backends:
      - name: rtx-2080ti
        priority: 10
        endpoint: http://100.x.x.x:11434

      - name: ollama-cloud
        priority: 100
        endpoint: https://ollama.com
        api_key_env: OLLAMA_CLOUD_API_KEY
