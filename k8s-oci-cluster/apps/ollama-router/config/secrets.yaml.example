# Copy to secrets.yaml in this directory and fill locally. Do not commit real values.
apiVersion: v1
kind: Secret
metadata:
  name: ollama-router-secrets
  namespace: ollama-router
type: Opaque
stringData:
  TS_AUTHKEY: tskey-auth-REPLACE_WITH_K8S_TAGGED_AUTH_KEY
  OLLAMA_CLOUD_API_KEY: REPLACE_WITH_OLLAMA_CLOUD_API_KEY
