# ── Required ──────────────────────────────────────────────────────────

domain               = "example.com"
letsencrypt_email    = "you@example.com"
cloudflare_api_token    = "your-cloudflare-api-token-here"

# Defaults to Cloudflare IPv4 ranges (see variables.tf). Override to add
# an operator IP for direct access or to use a different set of ranges.
# ingress_source_cidrs = ["203.0.113.5/32"]

# ── Optional ──────────────────────────────────────────────────────────

# kubeconfig_path = "~/.kube/k8s-oci-cluster-config"   # defaults to this
# git_repo_url    = "https://github.com/maslankalm/ai-lab.git"  # defaults to this
